# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=social_media_db

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRATION=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
# PRODUCTION: GOOGLE_CALLBACK_URL=https://your-api-domain.com/api/auth/google/callback
# Also register this URL in Google Cloud Console → APIs & Services → Credentials → Authorized redirect URIs

# Facebook OAuth
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback
# PRODUCTION: FACEBOOK_CALLBACK_URL=https://your-api-domain.com/api/auth/facebook/callback
# Also register this URL in Facebook Developer Portal → App → Facebook Login → Valid OAuth Redirect URIs

# App
APP_PORT=3000
APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:4200
FRONTEND_URL=http://localhost:4200
# PRODUCTION: CORS_ORIGIN=https://your-frontend-domain.com
# PRODUCTION: FRONTEND_URL=https://your-frontend-domain.com
NODE_ENV=development

# Cookie
# Options: strict | lax | none
# Use 'strict' for same-domain prod, 'none' for cross-subdomain prod (requires secure=true), 'lax' for dev
COOKIE_SAME_SITE=lax

# Redis
# Development: Memurai (Windows) or Redis — no password needed locally
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# PRODUCTION options (pick one):
# Option 1 — Redis Cloud (managed, free tier available): https://redis.io/cloud
#   REDIS_HOST=your-redis-cloud-host.redns.redis-cloud.com
#   REDIS_PORT=your-port
#   REDIS_PASSWORD=your-redis-cloud-password
# Option 2 — AWS ElastiCache, Upstash, Railway, Render Redis (set host + password accordingly)
# Option 3 — Self-hosted Redis on your server (set a strong requirepass in redis.conf)

# Upload
UPLOAD_DEST=./uploads
MAX_FILE_SIZE=5242880

# Storage (local or s3)
STORAGE_TYPE=local

# AWS S3 (only needed if STORAGE_TYPE=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Email/SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Social Media App" <noreply@app.com>
