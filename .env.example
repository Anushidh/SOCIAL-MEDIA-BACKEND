# Database
# Development: local Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=social_media_db
# PRODUCTION (Supabase Session Pooler — works on IPv4, free):
#   DB_HOST=aws-1-<region>.pooler.supabase.com
#   DB_PORT=5432
#   DB_USERNAME=postgres.<your-supabase-ref>
#   DB_PASSWORD=your-supabase-db-password
#   DB_NAME=postgres

# JWT — generate strong secrets at https://generate-secret.vercel.app/64
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRATION=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
# PRODUCTION: GOOGLE_CALLBACK_URL=https://your-backend.onrender.com/api/auth/google/callback
# Also register this URL in Google Cloud Console → APIs & Services → Credentials → Authorized redirect URIs

# Facebook OAuth
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback
# PRODUCTION: FACEBOOK_CALLBACK_URL=https://your-backend.onrender.com/api/auth/facebook/callback
# Also register this URL in Facebook Developer Portal → App → Facebook Login → Valid OAuth Redirect URIs

# App
APP_PORT=3000
APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:4200
FRONTEND_URL=http://localhost:4200
# PRODUCTION: CORS_ORIGIN=https://your-frontend.vercel.app
# PRODUCTION: FRONTEND_URL=https://your-frontend.vercel.app
NODE_ENV=development

# Cookie
# Options: strict | lax | none
# Use 'lax' for local dev, 'none' for production (frontend and backend on different domains)
COOKIE_SAME_SITE=lax

# Redis
# Development: Memurai (Windows) or local Redis — no password needed
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# PRODUCTION — Redis Cloud (free tier, no TLS required on standard ports):
#   REDIS_HOST=your-redis-host.redislabs.com
#   REDIS_PORT=your-port
#   REDIS_PASSWORD=your-redis-cloud-password
#   REDIS_DB=0

# Upload
UPLOAD_DEST=./uploads
MAX_FILE_SIZE=5242880

# Storage: local | cloudinary
STORAGE_TYPE=cloudinary

# Cloudinary (only needed if STORAGE_TYPE=cloudinary)
# Get these from https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email/SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Social Media App" <noreply@app.com>
